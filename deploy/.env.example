# Copy this to deploy/.env and fill with real values.
# docker compose reads deploy/.env automatically when invoked with
#   docker compose -f deploy/docker-compose.yml ...
#
# COINGLASS_API_KEY — required for orchestrator (leverage + capital_flows +
# market_stress + ingest-mcap). Gateway does not use it but a stray value
# is harmless.
COINGLASS_API_KEY=
